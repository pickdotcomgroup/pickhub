generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url     = env("DATABASE_URL")
}

model Post {
  id          Int      @id @default(autoincrement())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([name])
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                  String              @id @default(cuid())
  name                String?
  email               String?             @unique
  emailVerified       DateTime?
  image               String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  password            String?
  role                String              @default("user")
  accounts            Account[]
  adminProfile        AdminProfile?
  employerProfile     EmployerProfile?
  trainerProfile      TrainerProfile?
  applications        Application[]
  clientConversations Conversation[]      @relation("ClientConversations")
  talentConversations Conversation[]      @relation("TalentConversations")
  sentMessages        Message[]
  notifications       Notification[]
  posts               Post[]
  projects            Project[]
  sessions            Session[]
  talentProfile       TalentProfile?
  // Payment-related relations
  orders              Order[]
  enrollments         Enrollment[]
  payouts             Payout[]
  trainerCourses      Course[]            @relation("TrainerCourses")
  jobPostingPayments  JobPostingPayment[]
  // Job posting relations
  jobs                Job[]
  jobApplications     JobApplication[]
}

model EmployerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  firstName   String?
  lastName    String?
  companyName String?
  industry    String?
  companySize String?
  description String?
  website     String?
  location    String?
  foundedYear String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TalentProfile {
  id                 String              @id @default(cuid())
  userId             String              @unique
  firstName          String
  lastName           String
  title              String
  skills             String[]
  experience         String
  hourlyRate         String?
  portfolio          String?
  phone              String?
  resumeUrl          String?
  resumeName         String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  activePicks        Int                 @default(0)
  bio                String?
  certifications     String[]            @default([])
  completedProjects  Int                 @default(0)
  portfolioProjects  Json?
  portfolioUrl       String?
  successRate        Float               @default(0.0)
  tier               String              @default("bronze")
  totalEarnings      Float               @default(0.0)
  platformAccess     Boolean             @default(false)
  verificationStatus String              @default("pending")
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  verification       TalentVerification? @relation("TalentVerification")
}

model TrainerProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  organizationName   String
  organizationType   String?
  registrationNumber String?
  contactPersonName  String
  contactPersonRole  String?
  contactEmail       String?
  contactPhone       String?
  description        String?
  specializations    String[]
  trainingAreas      String[]  @default([])
  accreditations     String[]  @default([])
  website            String?
  location           String?
  foundedYear        String?
  organizationSize   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdminProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  firstName   String
  lastName    String
  role        String   @default("master")
  permissions Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TalentVerification {
  id                   String        @id @default(cuid())
  talentProfileId      String        @unique
  portfolioReviewed    Boolean       @default(false)
  portfolioScore       Float?
  portfolioNotes       String?
  githubUsername       String?
  gitlabUsername       String?
  codeRepositoryUrl    String?
  codeSampleReviewed   Boolean       @default(false)
  codeSampleScore      Float?
  codeSampleNotes      String?
  skillTestsTaken      Json?
  skillTestsScore      Float?
  linkedInUrl          String?
  linkedInVerified     Boolean       @default(false)
  identityVerified     Boolean       @default(false)
  identityDocumentType String?
  identityVerifiedAt   DateTime?
  overallScore         Float?
  verificationDecision String        @default("pending")
  reviewedBy           String?
  reviewedAt           DateTime?
  rejectionReason      String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  talentProfile        TalentProfile @relation("TalentVerification", fields: [talentProfileId], references: [id], onDelete: Cascade)

  @@index([verificationDecision])
}

model SkillTest {
  id           String   @id @default(cuid())
  title        String
  description  String
  technology   String
  difficulty   String
  duration     Int
  passingScore Float
  questions    Json
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([technology])
  @@index([difficulty])
}

model Project {
  id                 String             @id @default(cuid())
  projectKey         String             @unique
  title              String
  description        String
  budget             Float
  deadline           DateTime
  category           String
  skills             String[]
  projectType        String             @default("fixed")
  status             String             @default("open")
  clientId           String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  estimatedDuration  Int?
  projectTemplate    String?
  techStack          String[]           @default([])
  visibility         String             @default("public")
  minimumTier        String             @default("bronze")
  hourlyRate         Float?
  applications       Application[]
  tasks              Task[]
  milestones         Milestone[]
  client             User               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  jobPostingPayment  JobPostingPayment?

  @@index([clientId])
  @@index([status])
  @@index([category])
  @@index([minimumTier])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("todo")
  priority    String    @default("medium")
  dueDate     DateTime?
  assigneeId  String?
  createdBy   String
  projectId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([createdBy])
}

model Milestone {
  id          String    @id @default(cuid())
  title       String
  description String?
  amount      Float
  startDate   DateTime
  endDate     DateTime
  status      String    @default("pending")
  projectId   String
  createdBy   String
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([createdBy])
}

model Application {
  id             String    @id @default(cuid())
  status         String    @default("pending")
  coverLetter    String?
  proposedRate   Float?
  projectId      String
  talentId       String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  clientFeedback String?
  clientRating   Float?
  completedAt    DateTime?
  isPicked       Boolean   @default(false)
  pickedAt       DateTime?
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  talent         User      @relation(fields: [talentId], references: [id], onDelete: Cascade)

  @@unique([projectId, talentId])
  @@index([talentId])
  @@index([projectId])
  @@index([status])
  @@index([isPicked])
}

model Conversation {
  id               String    @id @default(cuid())
  clientId         String
  talentId         String
  projectId        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  mutualInterest   Boolean   @default(false)
  archivedByClient Boolean   @default(false)
  archivedByTalent Boolean   @default(false)
  deletedByClient  Boolean   @default(false)
  deletedByTalent  Boolean   @default(false)
  client           User      @relation("ClientConversations", fields: [clientId], references: [id], onDelete: Cascade)
  talent           User      @relation("TalentConversations", fields: [talentId], references: [id], onDelete: Cascade)
  messages         Message[]

  @@unique([clientId, talentId, projectId])
  @@index([clientId])
  @@index([talentId])
}

model Message {
  id             String       @id @default(cuid())
  content        String
  conversationId String
  senderId       String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Notification {
  id                   String   @id @default(cuid())
  type                 String
  title                String
  message              String
  isRead               Boolean  @default(false)
  userId               String
  relatedProjectId     String?
  relatedApplicationId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

// ==================== PAYMENT MODELS ====================

// Course catalog
model Course {
  id              String       @id @default(cuid())
  title           String
  description     String
  price           Float
  currency        String       @default("PHP")
  trainerId       String
  status          String       @default("draft") // draft, published, archived
  level           String       @default("beginner") // beginner, intermediate, advanced
  duration        String?      // e.g., "8 hours"
  thumbnail       String?
  category        String?
  skills          String[]     @default([])
  // Training availability options
  onlineAvailable Boolean      @default(true)
  onsiteAvailable Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  trainer         User         @relation("TrainerCourses", fields: [trainerId], references: [id], onDelete: Cascade)
  enrollments     Enrollment[]
  orders          Order[]

  @@index([trainerId])
  @@index([status])
  @@index([category])
}

// Order tracking for payments
model Order {
  id                  String    @id @default(cuid())
  userId              String
  courseId            String?
  paymongoCheckoutId  String    @unique
  paymongoPaymentId   String?
  type                String    // course_purchase, job_posting
  amount              Float
  currency            String    @default("PHP")
  platformFee         Float     // 15% of amount
  trainerPayout       Float?    // 85% of amount (for course purchases)
  status              String    @default("pending") // pending, paid, refunded, failed
  paidAt              DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course              Course?   @relation(fields: [courseId], references: [id], onDelete: SetNull)
  payout              Payout?

  @@index([userId])
  @@index([courseId])
  @@index([status])
  @@index([paymongoCheckoutId])
}

// Course enrollment records
model Enrollment {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  orderId     String?
  progress    Float     @default(0) // 0-100 percentage
  status      String    @default("active") // active, completed, paused, expired
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
}

// Trainer payout tracking
model Payout {
  id          String    @id @default(cuid())
  trainerId   String
  orderId     String    @unique
  amount      Float     // 85% of course price
  status      String    @default("pending") // pending, processing, completed, failed
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  trainer     User      @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([trainerId])
  @@index([status])
}

// Job posting payment for employers
model JobPostingPayment {
  id                 String    @id @default(cuid())
  employerId         String
  projectId          String    @unique
  paymongoCheckoutId String    @unique
  amount             Float
  type               String    // single_post, featured
  expiresAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  employer           User      @relation(fields: [employerId], references: [id], onDelete: Cascade)
  project            Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([employerId])
  @@index([projectId])
}

// ==================== JOB POSTING MODELS ====================

// Job postings by employers
model Job {
  id                   String           @id @default(cuid())
  // Basic Info
  title                String
  employmentType       String           // Full-time, Part-time, Contract, Freelance, Internship
  workLocationType     String           // Remote, On-site, Hybrid
  location             String?
  // Salary
  salaryMin            Float?
  salaryMax            Float?
  salaryPeriod         String?          // Per Year, Per Month, Per Hour, Per Project
  // Description
  description          String
  // Requirements
  experienceLevel      String           // Entry Level, Mid Level, Senior Level, Lead, Executive
  education            String?          // High School, Associate, Bachelor's, Master's, PhD, No Requirement
  skills               String[]         @default([])
  responsibilities     String?
  qualifications       String?
  // Benefits & Perks
  benefits             String[]         @default([])
  equity               String?
  signingBonus         Float?
  relocationAssistance Boolean          @default(false)
  visaSponsorship      Boolean          @default(false)
  // Status & Metadata
  status               String           @default("draft") // draft, active, closed
  viewCount            Int              @default(0)
  // Relations
  employerId           String
  employer             User             @relation(fields: [employerId], references: [id], onDelete: Cascade)
  applications         JobApplication[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([employerId])
  @@index([status])
  @@index([employmentType])
  @@index([workLocationType])
  @@index([experienceLevel])
}

// Job applications from talents
model JobApplication {
  id          String    @id @default(cuid())
  jobId       String
  talentId    String
  coverLetter String?
  resumeUrl   String?
  status      String    @default("pending") // pending, reviewed, shortlisted, rejected, hired
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  talent      User      @relation(fields: [talentId], references: [id], onDelete: Cascade)

  @@unique([jobId, talentId])
  @@index([jobId])
  @@index([talentId])
  @@index([status])
}
